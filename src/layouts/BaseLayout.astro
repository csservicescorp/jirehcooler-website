---
import '@/styles/global.css';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import MobileConversionBar from '@components/MobileConversionBar.astro';
import Seo from '@components/Seo.astro';
import site from '@data/site.json';

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  noindex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  hideMobileBar?: boolean;
}

const { title, description, path, image, noindex, schema, hideMobileBar = false } = Astro.props;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.businessName,
  url: 'https://jirehcooler.com',
};

const combinedSchema = schema ? [orgSchema, ...(Array.isArray(schema) ? schema : [schema])] : orgSchema;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#082b4c" />
    <Seo title={title} description={description} path={path} image={image} noindex={noindex} schema={combinedSchema} />
    <link rel="preload" href="/fonts/Inter-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Sora-Variable.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    {!hideMobileBar && <MobileConversionBar />}
    <script>
      // Progressive-enhancement scroll reveal (IntersectionObserver, no layout shift, respects reduced motion)
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const items = document.querySelectorAll('[data-reveal]');
      if (prefersReduced || !('IntersectionObserver' in window)) {
        items.forEach((el) => el.classList.add('is-visible'));
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
        );
        items.forEach((el) => observer.observe(el));
      }
    </script>
  </body>
</html>
