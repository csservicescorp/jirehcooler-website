---
import '@/styles/global.css';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import MobileConversionBar from '@components/MobileConversionBar.astro';
import Seo from '@components/Seo.astro';
import site from '@data/site.json';
import manifest from '@data/image-manifest.json';

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  noindex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  hideMobileBar?: boolean;
  /** Public path (e.g. /images/homepage/hero-x.jpg) of the page's LCP image, preloaded as WebP. */
  preloadImage?: string;
}

const { title, description, path, image, noindex, schema, hideMobileBar = false, preloadImage } = Astro.props;

type ManifestEntry = { width: number; height: number; smWidth: number; smHeight: number };
const preloadEntry: ManifestEntry | undefined = preloadImage ? (manifest as Record<string, ManifestEntry>)[preloadImage] : undefined;
const preloadBase = preloadImage?.replace(/\.jpg$/i, '');

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.businessName,
  url: 'https://jirehcooler.com',
};

const combinedSchema = schema ? [orgSchema, ...(Array.isArray(schema) ? schema : [schema])] : orgSchema;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#043688" />
    <Seo title={title} description={description} path={path} image={image} noindex={noindex} schema={combinedSchema} />
    <link rel="preload" href="/fonts/Inter-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Sora-Variable.woff2" as="font" type="font/woff2" crossorigin />
    {preloadEntry && preloadBase && (
      <link
        rel="preload"
        as="image"
        href={`${preloadBase}.webp`}
        imagesrcset={`${preloadBase}-sm.webp ${preloadEntry.smWidth}w, ${preloadBase}.webp ${preloadEntry.width}w`}
        imagesizes="(min-width: 720px) 45vw, 100vw"
        fetchpriority="high"
      />
    )}
    {import.meta.env.PUBLIC_GA4_ID && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA4_ID}`}></script>
        <script is:inline define:vars={{ GA4_ID: import.meta.env.PUBLIC_GA4_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', GA4_ID);
        </script>
      </>
    )}
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    {!hideMobileBar && <MobileConversionBar />}
    <script>
      // Progressive-enhancement scroll reveal (IntersectionObserver, no layout shift, respects reduced motion)
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const items = document.querySelectorAll('[data-reveal]');
      if (prefersReduced || !('IntersectionObserver' in window)) {
        items.forEach((el) => el.classList.add('is-visible'));
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
        );
        items.forEach((el) => observer.observe(el));
      }
    </script>
    <script>
      // Delegated conversion-event tracking: any element with data-track="event_name"
      // (optionally data-track-params='{"key":"value"}') fires a GA4 event on click,
      // only when analytics is actually loaded (PUBLIC_GA4_ID set).
      document.addEventListener('click', (e) => {
        const target = (e.target as HTMLElement)?.closest<HTMLElement>('[data-track]');
        if (!target) return;
        const eventName = target.dataset.track;
        if (!eventName) return;
        let params: Record<string, unknown> = {};
        if (target.dataset.trackParams) {
          try {
            params = JSON.parse(target.dataset.trackParams);
          } catch {
            /* ignore malformed params */
          }
        }
        const w = window as unknown as { gtag?: (...args: unknown[]) => void };
        if (typeof w.gtag === 'function') w.gtag('event', eventName, params);
      });
    </script>
  </body>
</html>
