---
import site from '@data/site.json';

interface Cta {
  label: string;
  href: string;
}
interface Props {
  heading: string;
  description?: string;
  primaryCta?: Cta;
  secondaryCta?: Cta;
  variant?: 'navy' | 'ice';
}
const {
  heading,
  description,
  primaryCta = { label: 'Call Now', href: `tel:${site.phoneRaw}` },
  secondaryCta = { label: 'Request an Estimate', href: '/request-an-estimate/' },
  variant = 'navy',
} = Astro.props;
---

<section class:list={['final-cta', variant === 'navy' ? 'section-navy' : 'section-ice']} data-reveal>
  <div class="container cta-inner">
    <div class="cta-copy">
      <h2>{heading}</h2>
      {description && <p>{description}</p>}
    </div>
    <div class="cta-actions">
      <a href={primaryCta.href} class:list={['btn', 'btn-lg', variant === 'navy' ? 'btn-white' : 'btn-primary']}>
        {primaryCta.label}
      </a>
      <a href={secondaryCta.href} class="btn btn-lg btn-outline">{secondaryCta.label}</a>
    </div>
  </div>
</section>

<style>
  .final-cta {
    border-radius: var(--radius-lg);
    margin-inline: var(--space-md);
    max-width: calc(var(--content-max) - 2 * var(--space-md));
    margin-inline: auto;
  }
  .cta-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    align-items: flex-start;
    justify-content: space-between;
  }
  .cta-copy h2 {
    max-width: 22ch;
  }
  .cta-copy p {
    max-width: 55ch;
  }
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  @media (min-width: 860px) {
    .cta-inner {
      flex-direction: row;
      align-items: center;
    }
  }
</style>
