---
interface Crumb {
  label: string;
  href: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.label,
    item: new URL(item.href, 'https://jirehcooler.com').toString(),
  })),
};
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol>
    {
      items.map((item, i) => (
        <li>
          {i === items.length - 1 ? (
            <span aria-current="page">{item.label}</span>
          ) : (
            <>
              <a href={item.href}>{item.label}</a>
              <span class="sep" aria-hidden="true">/</span>
            </>
          )}
        </li>
      ))
    }
  </ol>
</nav>
<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

<style>
  .breadcrumbs {
    padding-block: var(--space-sm);
  }
  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.35rem;
    font-size: var(--fs-xs);
  }
  .breadcrumbs li {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .breadcrumbs a {
    color: var(--color-muted);
  }
  .breadcrumbs a:hover {
    color: var(--color-royal);
  }
  .breadcrumbs [aria-current='page'] {
    color: var(--color-charcoal);
    font-weight: 600;
  }
  .sep {
    color: var(--color-border-strong);
  }
</style>
