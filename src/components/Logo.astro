---
// Official Jireh Cooler logo. Rendered undistorted (natural aspect ratio,
// object-fit: contain, never cropped) — unlike ResponsiveImage, which crops
// photos to a fixed aspect ratio. Reads the path/alt from Website Settings
// (src/data/site.json → logo) so the client can swap the logo file and edit
// its alt text through Pages CMS without a code change.

import site from '@data/site.json';
import manifest from '@data/image-manifest.json';

interface Props {
  height?: number; // desktop display height in px; width follows the logo's natural ratio
  mobileHeight?: number; // optional different height below 720px; defaults to `height`
  class?: string;
}

const { height = 44, mobileHeight, class: className = '' } = Astro.props;
const mHeight = mobileHeight ?? height;

type ManifestEntry = { width: number; height: number; smWidth: number; smHeight: number };
const src = site.logo.image;
const alt = site.logo.alt;
const entry: ManifestEntry | undefined = (manifest as Record<string, ManifestEntry>)[src];
const base = src.replace(/\.(png|jpg)$/i, '');
const maxHeight = Math.max(height, mHeight);
const displayWidth = entry ? Math.round((maxHeight * entry.width) / entry.height) : undefined;
const sizeVars = `--logo-h:${height}px;--logo-h-mobile:${mHeight}px;`;
---

{
  entry ? (
    <picture>
      <source
        type="image/avif"
        srcset={`${base}-sm.avif ${entry.smWidth}w, ${base}.avif ${entry.width}w`}
        sizes={`${displayWidth}px`}
      />
      <source
        type="image/webp"
        srcset={`${base}-sm.webp ${entry.smWidth}w, ${base}.webp ${entry.width}w`}
        sizes={`${displayWidth}px`}
      />
      <img
        class={`logo-img ${className}`}
        src={`${base}.png`}
        srcset={`${base}-sm.png ${entry.smWidth}w, ${base}.png ${entry.width}w`}
        sizes={`${displayWidth}px`}
        width={entry.width}
        height={entry.height}
        alt={alt}
        loading="eager"
        decoding="async"
        style={sizeVars}
      />
    </picture>
  ) : (
    // Newly-uploaded logo not yet processed by scripts/optimize-images.mjs —
    // render it directly rather than break the header.
    <img class={`logo-img ${className}`} src={src} alt={alt} loading="eager" decoding="async" style={sizeVars} />
  )
}

<style>
  .logo-img {
    display: block;
    object-fit: contain;
    max-width: 100%;
    height: var(--logo-h);
    width: auto;
  }
  @media (max-width: 719px) {
    .logo-img {
      height: var(--logo-h-mobile);
    }
  }
</style>
