---
interface Step {
  step: string;
  label: string;
  description: string;
}
interface Props {
  steps: Step[];
}
const { steps } = Astro.props;
---

<ol class="process-list">
  {
    steps.map((s, i) => (
      <li class="process-item" data-reveal style={`transition-delay:${i * 70}ms`}>
        <span class="process-num">{s.step}</span>
        <div>
          <h3>{s.label}</h3>
          <p>{s.description}</p>
        </div>
      </li>
    ))
  }
</ol>

<style>
  .process-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-lg);
    counter-reset: step;
  }
  .process-item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--space-md);
    align-items: flex-start;
    position: relative;
    padding-bottom: var(--space-lg);
  }
  .process-item:not(:last-child)::before {
    content: '';
    position: absolute;
    left: 27px;
    top: 56px;
    bottom: 0;
    width: 1.5px;
    background: var(--color-border-strong);
  }
  .section-royal .process-item:not(:last-child)::before {
    background: rgba(255, 255, 255, 0.18);
  }
  .process-num {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    place-items: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--gradient-blue);
    color: var(--color-white);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--fs-lg);
    flex-shrink: 0;
  }
  .process-item h3 {
    margin-bottom: 0.25rem;
  }
  .process-item p {
    margin: 0;
    max-width: 55ch;
  }

  @media (min-width: 860px) {
    .process-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-xl) var(--space-2xl);
    }
  }
</style>
