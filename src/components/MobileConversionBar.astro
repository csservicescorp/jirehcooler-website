---
import site from '@data/site.json';
import Icon from './Icon.astro';
---

<div class="mobile-bar" role="region" aria-label="Quick contact">
  <a href={`tel:${site.phoneRaw}`} class="mobile-bar-btn call">
    <Icon name="phone" class="icon-sm" />
    Call Now
  </a>
  <a href="/request-an-estimate/" class="mobile-bar-btn estimate">
    <Icon name="document" class="icon-sm" />
    Request Estimate
  </a>
</div>

<style>
  .mobile-bar {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: var(--z-mobile-bar);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    box-shadow: 0 -6px 20px rgba(8, 43, 76, 0.16);
    padding-bottom: env(safe-area-inset-bottom, 0);
  }
  .mobile-bar-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    padding: 0.9rem 0.5rem;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--fs-sm);
  }
  .mobile-bar-btn.call {
    background: var(--color-royal);
    color: var(--color-white);
  }
  .mobile-bar-btn.estimate {
    background: var(--color-blue);
    color: var(--color-white);
  }
  .icon-sm {
    width: 17px;
    height: 17px;
  }

  @media (min-width: 1080px) {
    .mobile-bar {
      display: none;
    }
  }
</style>
