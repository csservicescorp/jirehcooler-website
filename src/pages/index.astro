---
import BaseLayout from '@layouts/BaseLayout.astro';
import Icon from '@components/Icon.astro';
import ResponsiveImage from '@components/ResponsiveImage.astro';
import TrustPoints from '@components/TrustPoints.astro';
import ServiceCard from '@components/ServiceCard.astro';
import ProcessSteps from '@components/ProcessSteps.astro';
import FaqAccordion from '@components/FaqAccordion.astro';
import ReviewCard from '@components/ReviewCard.astro';
import CtaSection from '@components/CtaSection.astro';
import site from '@data/site.json';
import home from '@data/homepage.json';
import { getCollection } from 'astro:content';
import { localBusinessSchema } from '@/lib/schema';

const allServices = await getCollection('services', ({ data }) => data.published);
const featured = home.services.featuredSlugs
  .map((slug) => allServices.find((s) => s.data.urlSlug === slug))
  .filter(Boolean);

const faqs = (await getCollection('faqs')).sort((a, b) => a.data.order - b.data.order).slice(0, 6);
const areas = (await getCollection('serviceAreas', ({ data }) => data.published)).slice(0, 8);
const featuredReviews = (await getCollection('testimonials', ({ data }) => data.published && data.featured))
  .sort((a, b) => a.data.displayOrder - b.data.displayOrder)
  .slice(0, 3);
---

<BaseLayout
  title="Jireh Cooler | South Florida Air Conditioning Experts"
  description="Family-operated, state-certified AC repair, installation, and maintenance in Broward and Palm Beach County since 1994. 24/7 emergency service."
  schema={localBusinessSchema()}
  preloadImage={home.hero.image}
>
  <!-- HERO -->
  <section class="hero-photo">
    <div class="hero-bg">
      <ResponsiveImage
        src={home.hero.image}
        alt={home.hero.imageAlt}
        ratio="16 / 9"
        mobileRatio="4 / 5"
        focal="22% 40%"
        variant="background"
        rounded={false}
        priority
        sizes="100vw"
      />
      <div class="hero-scrim" aria-hidden="true"></div>
    </div>
    <div class="container hero-inner">
      <div class="hero-copy" data-reveal>
        <p class="eyebrow eyebrow-desktop">{home.hero.eyebrow}</p>
        <p class="eyebrow eyebrow-mobile">{home.hero.mobileEyebrow}</p>
        <h1>{home.hero.headline}</h1>
        <p class="hero-sub hero-sub-desktop">{home.hero.subheadline}</p>
        <p class="hero-sub hero-sub-mobile">{home.hero.mobileSubheadline}</p>
        <div class="hero-actions">
          <a href={home.hero.primaryCta.href} class="btn btn-primary btn-lg">
            <Icon name="phone" class="icon-sm" />
            {home.hero.primaryCta.label}
          </a>
          <a href={home.hero.secondaryCta.href} class="btn btn-outline btn-lg">{home.hero.secondaryCta.label}</a>
        </div>
        <ul class="hero-facts hero-facts-desktop">
          <li><Icon name="shield" class="icon-sm" /> License {site.license.number}</li>
          <li><Icon name="clock" class="icon-sm" /> {site.emergencyAvailability} Emergency Service</li>
          <li><Icon name="calendar" class="icon-sm" /> Serving South Florida Since {site.foundedYear}</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- MOBILE TRUST STRIP (hero facts, moved out of the hero image area on small screens) -->
  <ul class="container trust-strip">
    <li><Icon name="shield" class="icon-sm" /> License {site.license.number}</li>
    <li><Icon name="clock" class="icon-sm" /> {site.emergencyAvailability} Emergency Service</li>
    <li><Icon name="calendar" class="icon-sm" /> Serving South Florida Since {site.foundedYear}</li>
  </ul>

  <!-- PATHWAYS -->
  <section class="pathways">
    <div class="container">
      <div class="section-head center">
        <h2>{home.pathways.heading}</h2>
      </div>
      <div class="pathway-grid">
        <a href={home.pathways.residential.href} class="pathway-card" data-reveal>
          <ResponsiveImage src={home.pathways.residential.image} alt={home.pathways.residential.imageAlt} ratio="16 / 10" variant="card" />
          <div class="pathway-body">
            <h3>{home.pathways.residential.label}</h3>
            <p>{home.pathways.residential.description}</p>
            <span class="pathway-link">Explore Residential <Icon name="arrow-right" class="icon-xs" /></span>
          </div>
        </a>
        <a href={home.pathways.commercial.href} class="pathway-card" data-reveal style="transition-delay:80ms">
          <ResponsiveImage src={home.pathways.commercial.image} alt={home.pathways.commercial.imageAlt} ratio="16 / 10" variant="card" />
          <div class="pathway-body">
            <h3>{home.pathways.commercial.label}</h3>
            <p>{home.pathways.commercial.description}</p>
            <span class="pathway-link">Explore Commercial <Icon name="arrow-right" class="icon-xs" /></span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- TRUST -->
  <section class="section-royal trust-section">
    <div class="container trust-grid-layout">
      <div class="trust-media" data-reveal>
        <ResponsiveImage
          src={home.trust.image}
          alt={home.trust.imageAlt}
          ratio="5 / 4"
          mobileRatio="4 / 3"
          variant="editorial"
        />
      </div>
      <div class="trust-copy">
        <div class="section-head">
          <p class="eyebrow">Why South Florida Trusts Us</p>
          <h2>{home.trust.heading}</h2>
          <p>{home.trust.subheading}</p>
        </div>
        <TrustPoints points={home.trust.points} columns={2} />
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="services-section">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">Complete AC Services</p>
        <h2>{home.services.heading}</h2>
        <p>{home.services.subheading}</p>
      </div>
      <div class="services-grid">
        {
          featured.map((service) => (
            <ServiceCard
              title={service!.data.title}
              description={service!.data.shortDescription}
              href={`/${service!.data.urlSlug}/`}
              icon={service!.data.icon}
            />
          ))
        }
      </div>
      <div class="services-cta">
        <a href="/services/" class="btn btn-outline">View All Services</a>
      </div>
    </div>
  </section>

  <!-- EMERGENCY (full-bleed editorial photo, not another flat color block) -->
  <section class="emergency-section">
    <div class="emergency-bg">
      <ResponsiveImage src={home.emergency.image} alt={home.emergency.imageAlt} ratio="16 / 9" variant="background" rounded={false} sizes="100vw" />
      <div class="emergency-scrim" aria-hidden="true"></div>
    </div>
    <div class="container emergency-inner" data-reveal>
      <p class="eyebrow">Emergency Service</p>
      <h2>{home.emergency.heading}</h2>
      <p>{home.emergency.description}</p>
      <div class="hero-actions">
        <a href={home.emergency.cta.href} class="btn btn-primary btn-lg">
          <Icon name="bolt" class="icon-sm" />
          {home.emergency.cta.label}
        </a>
        <a href={home.emergency.href} class="btn btn-outline btn-lg">Learn More</a>
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE US -->
  <section class="section-soft why-section">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">The Jireh Cooler Difference</p>
        <h2>{home.whyChooseUs.heading}</h2>
      </div>
      <TrustPoints points={home.whyChooseUs.points} columns={4} />
    </div>
  </section>

  <!-- PROCESS -->
  <section class="process-section">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">How It Works</p>
        <h2>{home.process.heading}</h2>
      </div>
      <ProcessSteps steps={home.process.steps} />
    </div>
  </section>

  <!-- MEMBERSHIP -->
  <section class="section-royal membership-section">
    <div class="container membership-grid">
      <div data-reveal>
        <ResponsiveImage src={home.membership.image} alt={home.membership.imageAlt} ratio="4 / 3" variant="editorial" />
      </div>
      <div data-reveal>
        <p class="eyebrow">Preventive Maintenance</p>
        <h2>{home.membership.heading}</h2>
        <p>{home.membership.description}</p>
        <ul class="check-list">
          {home.membership.highlights.map((h) => (
            <li><Icon name="check" class="icon-sm" /> {h}</li>
          ))}
        </ul>
        <a href={home.membership.cta.href} class="btn btn-white btn-lg">{home.membership.cta.label}</a>
      </div>
    </div>
  </section>

  <!-- FINANCING -->
  <section class="financing-section">
    <div class="container financing-grid">
      <div data-reveal>
        <p class="eyebrow">Financing</p>
        <h2>{home.financing.heading}</h2>
        <p>{home.financing.description}</p>
        <a href={home.financing.cta.href} class="btn btn-primary btn-lg">{home.financing.cta.label}</a>
      </div>
      <div data-reveal>
        <ResponsiveImage src={home.financing.image} alt={home.financing.imageAlt} ratio="4 / 3" focal="center 38%" variant="editorial" />
      </div>
    </div>
  </section>

  <!-- AIR QUALITY -->
  <section class="section-ice air-quality-section">
    <div class="container air-grid">
      <div data-reveal>
        <ResponsiveImage src={home.airQuality.image} alt={home.airQuality.imageAlt} ratio="4 / 3" variant="editorial" />
      </div>
      <div data-reveal>
        <p class="eyebrow">Indoor Air Quality</p>
        <h2>{home.airQuality.heading}</h2>
        <p>{home.airQuality.description}</p>
        <a href={home.airQuality.cta.href} class="btn btn-primary btn-lg">{home.airQuality.cta.label}</a>
      </div>
    </div>
  </section>

  <!-- CUSTOMER STORIES -->
  <section class="reviews-teaser">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">Customer Stories</p>
        <h2>What Our Customers Say</h2>
      </div>
      {featuredReviews.length > 0 ? (
        <div class="reviews-grid">
          {featuredReviews.map((r) => (
            <ReviewCard
              reviewerName={r.data.reviewerName}
              rating={r.data.rating}
              reviewText={r.data.reviewText}
              reviewDate={r.data.reviewDate}
              sourceLabel={r.data.sourceLabel}
              sourceUrl={r.data.sourceUrl}
              featured
            />
          ))}
        </div>
      ) : (
        <p class="reviews-empty container-narrow">
          Real customer reviews are being added to this page. Visit our Google Business Profile for current, verified reviews in the meantime.
        </p>
      )}
      <div class="reviews-actions">
        <a href={site.googleProfileUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">Read More Reviews</a>
        <a href={site.googleProfileUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline">Leave Us a Review</a>
      </div>
    </div>
  </section>

  <!-- SERVICE AREAS -->
  <section class="section-soft areas-section">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">Where We Work</p>
        <h2>Proudly Serving {site.serviceAreaSummary}</h2>
      </div>
      <ul class="areas-list">
        {areas.map((area) => (
          <li>
            <Icon name="pin" class="icon-sm" /> {area.data.city}
          </li>
        ))}
      </ul>
      <div class="services-cta">
        <a href="/service-areas/" class="btn btn-outline">View All Service Areas</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="container container-narrow">
      <div class="section-head center">
        <p class="eyebrow">Common Questions</p>
        <h2>Frequently Asked Questions</h2>
      </div>
      <FaqAccordion faqs={faqs.map((f) => f.data)} />
      <div class="services-cta">
        <a href="/faq/" class="btn btn-outline">View All FAQs</a>
      </div>
    </div>
  </section>

  <CtaSection
    heading={home.finalCta.heading}
    description={home.finalCta.description}
    primaryCta={home.finalCta.primaryCta}
    secondaryCta={home.finalCta.secondaryCta}
    backgroundImage={home.finalCta.backgroundImage}
    backgroundImageAlt={home.finalCta.backgroundImageAlt}
  />
</BaseLayout>

<style>
  .hero-photo {
    position: relative;
    overflow: hidden;
    min-height: 520px;
    display: flex;
    align-items: center;
    /* Subtle angled lower edge — mobile/small-tablet only (see below), a
       bold branded panel rather than a plain rectangle. */
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 95%);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-bg :global(.rimg) {
    height: 100%;
    aspect-ratio: auto;
  }
  .hero-scrim {
    position: absolute;
    inset: 0;
    /* Mobile default: a bold, on-brand royal-blue panel over the photo
       (lighter near the top so the office is still visible, strongly
       royal-blue toward the bottom where the text sits) rather than a
       generic dark tint. */
    background: linear-gradient(180deg, rgba(4, 54, 136, 0.32) 0%, rgba(4, 40, 92, 0.74) 45%, rgba(4, 23, 58, 0.94) 100%);
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    padding-block: var(--space-xl);
    display: flex;
    justify-content: center;
  }
  .hero-copy {
    max-width: 640px;
    text-align: center;
    margin-inline: auto;
  }
  .eyebrow-desktop,
  .hero-sub-desktop {
    display: none;
  }
  .hero-facts {
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    list-style: none;
    margin: var(--space-sm) 0 0;
    padding: 0;
    font-size: var(--fs-xs);
    font-weight: 600;
    color: var(--color-white);
  }
  .hero-facts li {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .hero-facts-desktop {
    display: none;
  }
  .trust-strip {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    list-style: none;
    padding-block: var(--space-md);
    background: var(--color-white);
    border-bottom: 1px solid var(--color-border);
  }
  .trust-strip li {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-size: var(--fs-xs);
    font-weight: 600;
    color: var(--color-royal);
  }
  @media (min-width: 720px) {
    .hero-photo {
      clip-path: none;
    }
    .hero-scrim {
      /* Tablet/desktop default: uniformly strong neutral scrim, since the
         stacked, nearly full-width copy column doesn't leave room to
         dodge the logo wall visible in the photo's left portion. */
      background: rgba(4, 14, 32, 0.78);
    }
    .hero-inner {
      justify-content: flex-start;
    }
    .hero-copy {
      max-width: 640px;
      text-align: left;
      margin-inline: 0;
    }
    .eyebrow-mobile,
    .hero-sub-mobile {
      display: none;
    }
    .eyebrow-desktop,
    .hero-sub-desktop {
      display: block;
    }
    .hero-facts-desktop {
      display: flex;
    }
    .trust-strip {
      display: none;
    }
  }
  @media (min-width: 1280px) {
    /* Only once the container reaches its own max-width is there enough
       spare room on the left for the copy column to fully clear the
       office's logo wall — swap to a left/right gradient so the logo
       stays visible instead of being flatly darkened. */
    .hero-scrim {
      background: linear-gradient(90deg, rgba(4, 20, 45, 0.28) 0%, rgba(4, 16, 36, 0.62) 45%, rgba(4, 12, 28, 0.92) 100%);
    }
    .hero-inner {
      justify-content: flex-end;
    }
  }
  .hero-copy .eyebrow {
    color: var(--color-cyan);
  }
  .hero-copy h1 {
    color: var(--color-white);
  }
  .hero-sub {
    font-size: var(--fs-md);
    max-width: 52ch;
    color: rgba(255, 255, 255, 0.86);
  }
  @media (max-width: 719px) {
    .hero-sub {
      margin-inline: auto;
    }
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-block: var(--space-md);
  }
  @media (max-width: 719px) {
    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }
    .hero-actions .btn {
      justify-content: center;
    }
  }
  .hero-photo .btn-outline {
    background: rgba(4, 54, 136, 0.35);
    border-color: rgba(255, 255, 255, 0.55);
    color: var(--color-white);
  }
  .hero-photo .btn-outline:hover {
    background: rgba(4, 54, 136, 0.55);
    border-color: var(--color-white);
  }
  .icon-sm {
    width: 18px;
    height: 18px;
  }
  .icon-xs {
    width: 15px;
    height: 15px;
  }

  .pathway-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-lg);
  }
  .pathway-card {
    display: block;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition: transform var(--duration-base) var(--ease-out), box-shadow var(--duration-base) var(--ease-out);
  }
  .pathway-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  .pathway-card:hover :global(img) {
    transform: scale(1.04);
  }
  .pathway-card :global(.rimg) {
    border-radius: 0;
  }
  .pathway-body {
    padding: var(--space-lg);
  }
  .pathway-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-royal);
  }

  .services-grid {
    display: grid;
    gap: var(--space-md);
    grid-template-columns: minmax(0, 1fr);
  }
  .services-cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-xl);
  }

  .trust-grid-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-xl);
    align-items: center;
  }
  .trust-copy .section-head {
    margin-bottom: var(--space-lg);
  }

  .emergency-section {
    position: relative;
    padding-block: var(--space-3xl);
    color: var(--color-white);
    overflow: hidden;
  }
  .emergency-bg {
    position: absolute;
    inset: 0;
  }
  .emergency-bg :global(.rimg) {
    height: 100%;
    aspect-ratio: auto;
  }
  .emergency-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(100deg, rgba(4, 54, 136, 0.92) 0%, rgba(10, 45, 102, 0.82) 45%, rgba(10, 45, 102, 0.55) 100%);
  }
  .emergency-inner {
    position: relative;
    z-index: 1;
    max-width: 620px;
  }
  .emergency-inner .eyebrow {
    color: var(--color-cyan);
  }
  .emergency-inner h2 {
    color: var(--color-white);
  }
  .emergency-inner p {
    color: rgba(255, 255, 255, 0.82);
  }
  .emergency-inner .btn-outline {
    background: rgba(4, 54, 136, 0.35);
    border-color: rgba(255, 255, 255, 0.55);
    color: var(--color-white);
  }
  .emergency-inner .btn-outline:hover {
    background: rgba(4, 54, 136, 0.55);
    border-color: var(--color-white);
  }

  .membership-grid,
  .financing-grid,
  .air-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-xl);
    align-items: center;
  }
  .check-list {
    list-style: none;
    margin: var(--space-sm) 0 var(--space-md);
    padding: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0.6rem;
  }
  .check-list li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .reviews-teaser {
    text-align: center;
  }
  .reviews-grid {
    display: grid;
    align-items: start;
    gap: var(--space-md);
    grid-template-columns: minmax(0, 1fr);
    text-align: left;
    margin-bottom: var(--space-lg);
  }
  @media (min-width: 720px) {
    .reviews-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (min-width: 960px) {
    .reviews-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
  .reviews-empty {
    color: var(--color-muted);
    margin-inline: auto;
    margin-bottom: var(--space-lg);
  }
  .reviews-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .areas-list {
    list-style: none;
    margin: 0 0 var(--space-lg);
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    max-width: 760px;
    margin-inline: auto;
  }
  .areas-list li {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 600;
    color: var(--color-royal);
    font-size: var(--fs-sm);
  }

  @media (min-width: 720px) {
    .hero-photo {
      min-height: 680px;
    }
    .pathway-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .services-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .trust-grid-layout {
      grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    }
    .membership-grid,
    .financing-grid,
    .air-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    }
    .financing-grid > div:first-child {
      order: 1;
    }
    .financing-grid > div:last-child {
      order: 2;
    }
    .areas-list {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
  @media (min-width: 960px) {
    .services-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    .hero-photo {
      min-height: 760px;
    }
  }
</style>
