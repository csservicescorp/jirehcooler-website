---
import BaseLayout from '@layouts/BaseLayout.astro';
import Icon from '@components/Icon.astro';
import site from '@data/site.json';
---

<BaseLayout
  title="Page Not Found | Jireh Cooler"
  description="The page you're looking for couldn't be found."
  noindex
>
  <section class="not-found section-navy">
    <div class="container">
      <span class="nf-icon"><Icon name="wind" stroke-width={1.2} /></span>
      <p class="eyebrow">404</p>
      <h1>We Couldn't Find That Page</h1>
      <p>The page you're looking for may have moved or no longer exists. Let's get you back on track.</p>
      <div class="nf-actions">
        <a href="/" class="btn btn-white btn-lg">Back to Home</a>
        <a href={`tel:${site.phoneRaw}`} class="btn btn-outline btn-lg">Call {site.phone}</a>
      </div>
      <nav class="nf-links" aria-label="Popular pages">
        <a href="/services/">Services</a>
        <a href="/about/">About</a>
        <a href="/contact/">Contact</a>
        <a href="/request-an-estimate/">Request an Estimate</a>
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 70vh;
    display: flex;
    align-items: center;
    text-align: center;
  }
  .not-found .container {
    max-width: 640px;
  }
  .nf-icon {
    display: inline-grid;
    place-items: center;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    color: var(--color-blue-light);
    margin-bottom: var(--space-md);
  }
  .nf-icon :global(svg) {
    width: 34px;
    height: 34px;
  }
  .not-found .eyebrow {
    justify-content: center;
  }
  .nf-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin: var(--space-lg) 0;
  }
  .nf-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
    font-size: var(--fs-sm);
  }
  .nf-links a {
    color: rgba(255, 255, 255, 0.75);
  }
  .nf-links a:hover {
    color: var(--color-white);
  }
</style>
