---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';
import EstimateForm from '@components/EstimateForm.astro';
import Icon from '@components/Icon.astro';
import ResponsiveImage from '@components/ResponsiveImage.astro';
import site from '@data/site.json';

const mapQuery = encodeURIComponent(site.address.full);
const mapEmbedSrc = `https://www.google.com/maps?q=${mapQuery}&output=embed`;
const directionsHref = `https://www.google.com/maps/dir/?api=1&destination=${mapQuery}`;
---

<BaseLayout
  title="Contact Jireh Cooler | South Florida AC Company"
  description="Contact Jireh Cooler by phone, email, or our online form. Located in Deerfield Beach, serving Broward and Palm Beach County."
  path="/contact/"
>
  <PageHero
    eyebrow="Contact"
    title="Get in Touch"
    description="Have a question or want to schedule service? Reach out any way that's convenient for you."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Contact', href: '/contact/' },
    ]}
  />

  <section>
    <div class="container contact-grid">
      <div class="contact-info" data-reveal>
        <ul class="info-list">
          <li>
            <Icon name="phone" class="icon-md" />
            <div>
              <h3>Phone</h3>
              <a href={`tel:${site.phoneRaw}`} data-track="phone_click" data-track-params={JSON.stringify({ location: 'contact_page' })}>{site.phone}</a>
            </div>
          </li>
          <li>
            <Icon name="mail" class="icon-md" />
            <div>
              <h3>Email</h3>
              <a href={`mailto:${site.email}`}>{site.email}</a>
            </div>
          </li>
          <li>
            <Icon name="pin" class="icon-md" />
            <div>
              <h3>Address</h3>
              <p>{site.address.full}</p>
            </div>
          </li>
          <li>
            <Icon name="clock" class="icon-md" />
            <div>
              <h3>Hours</h3>
              <p>{site.hours.office}</p>
              <p class="emergency-note">{site.hours.emergency}</p>
            </div>
          </li>
        </ul>
        <a
          href={directionsHref}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary btn-block directions-btn"
          data-track="directions_click"
          data-track-params={JSON.stringify({ location: 'contact_page' })}
        >
          <Icon name="pin" class="icon-sm" /> Get Directions
        </a>
        <ResponsiveImage
          src="/images/homepage/jireh-cooler-office-hero.jpg"
          alt="Jireh Cooler office reception area with the company logo on the accent wall"
          ratio="4 / 3"
          focal="22% 40%"
          variant="editorial"
          fallbackIcon="map"
        />
      </div>
      <div class="form-panel card" data-reveal>
        <h2>Send a Message</h2>
        <EstimateForm formType="contact" compact />
      </div>
    </div>
  </section>

  <section class="section-soft map-section">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">Find Us</p>
        <h2>{site.address.full}</h2>
      </div>
      <div class="map-embed">
        <iframe
          src={mapEmbedSrc}
          title={`Map showing the location of Jireh Cooler at ${site.address.full}`}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-xl);
  }
  .info-list {
    list-style: none;
    margin: 0 0 var(--space-lg);
    padding: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-md);
  }
  .info-list li {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
  }
  .icon-md {
    width: 24px;
    height: 24px;
    color: var(--color-royal);
    flex-shrink: 0;
    margin-top: 0.15rem;
  }
  .icon-sm {
    width: 18px;
    height: 18px;
  }
  .info-list h3 {
    font-size: var(--fs-sm);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-bottom: 0.15rem;
  }
  .info-list p,
  .info-list a {
    margin: 0;
    color: var(--color-charcoal);
    font-weight: 500;
  }
  .emergency-note {
    color: var(--color-royal);
    font-weight: 600;
  }
  .directions-btn {
    margin-bottom: var(--space-lg);
  }
  .form-panel {
    padding: var(--space-xl);
  }
  .map-section {
    text-align: center;
  }
  .map-embed {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    aspect-ratio: 16 / 9;
  }
  .map-embed iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }
  @media (min-width: 720px) {
    .map-embed {
      aspect-ratio: 21 / 9;
    }
  }
  @media (min-width: 960px) {
    .contact-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.3fr);
    }
  }
</style>
