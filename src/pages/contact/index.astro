---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';
import EstimateForm from '@components/EstimateForm.astro';
import Icon from '@components/Icon.astro';
import ImagePlaceholder from '@components/ImagePlaceholder.astro';
import site from '@data/site.json';
---

<BaseLayout
  title="Contact Jireh Cooler | South Florida AC Company"
  description="Contact Jireh Cooler by phone, email, or our online form. Located in Deerfield Beach, serving Broward and Palm Beach County."
  path="/contact/"
>
  <PageHero
    eyebrow="Contact"
    title="Get in Touch"
    description="Have a question or want to schedule service? Reach out any way that's convenient for you."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Contact', href: '/contact/' },
    ]}
  />

  <section>
    <div class="container contact-grid">
      <div class="contact-info" data-reveal>
        <ul class="info-list">
          <li>
            <Icon name="phone" class="icon-md" />
            <div>
              <h3>Phone</h3>
              <a href={`tel:${site.phoneRaw}`}>{site.phone}</a>
            </div>
          </li>
          <li>
            <Icon name="mail" class="icon-md" />
            <div>
              <h3>Email</h3>
              <a href={`mailto:${site.email}`}>{site.email}</a>
            </div>
          </li>
          <li>
            <Icon name="pin" class="icon-md" />
            <div>
              <h3>Address</h3>
              <p>{site.address.full}</p>
            </div>
          </li>
          <li>
            <Icon name="clock" class="icon-md" />
            <div>
              <h3>Hours</h3>
              <p>{site.hours.office}</p>
              <p>{site.hours.emergency}</p>
            </div>
          </li>
        </ul>
        <ImagePlaceholder icon="map" ratio="4 / 3" variant="ice" label="Service Area Map" />
      </div>
      <div class="form-panel card" data-reveal>
        <h2>Send a Message</h2>
        <EstimateForm formType="contact" compact />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-xl);
  }
  .info-list {
    list-style: none;
    margin: 0 0 var(--space-lg);
    padding: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-md);
  }
  .info-list li {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
  }
  .icon-md {
    width: 24px;
    height: 24px;
    color: var(--color-blue);
    flex-shrink: 0;
    margin-top: 0.15rem;
  }
  .info-list h3 {
    font-size: var(--fs-sm);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-bottom: 0.15rem;
  }
  .info-list p,
  .info-list a {
    margin: 0;
    color: var(--color-charcoal);
    font-weight: 500;
  }
  .form-panel {
    padding: var(--space-xl);
  }
  @media (min-width: 960px) {
    .contact-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.3fr);
    }
  }
</style>
