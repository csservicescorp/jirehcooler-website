---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';
import ResponsiveImage from '@components/ResponsiveImage.astro';
import Icon from '@components/Icon.astro';
import CtaSection from '@components/CtaSection.astro';
import ServiceCard from '@components/ServiceCard.astro';
import ReviewCard from '@components/ReviewCard.astro';
import ServiceGallery from '@components/ServiceGallery.astro';
import site from '@data/site.json';
import { serviceSchema } from '@/lib/schema';

export async function getStaticPaths() {
  const services = await getCollection('services', ({ data }) => data.published);
  return services.map((service) => ({
    params: { slug: service.data.urlSlug },
    props: { service, allSlugs: services.map((s) => s.data.urlSlug) },
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);
const allServices = await getCollection('services', ({ data }) => data.published);
const related = allServices.filter((s) => s.data.urlSlug !== service.data.urlSlug).slice(0, 3);
const path = `/${service.data.urlSlug}/`;
// Emergency service's CTA is a direct phone call, not the estimate form.
const isEmergency = service.data.urlSlug === 'emergency-ac-service';
const ctaHref = isEmergency ? `tel:${site.phoneRaw}` : `/request-an-estimate/?service=${service.data.urlSlug}`;

// Thematically-matched real review shown on the five highest-priority
// service pages, pulled from the same authentic testimonials collection
// used on the Reviews page — never a fabricated quote.
const RELATED_REVIEWER: Record<string, string> = {
  'ac-repair': 'Paul Clippinger',
  'ac-installation-and-replacement': 'marcus nunes',
  'emergency-ac-service': 'Joao Neto',
  'residential-hvac': 'Leticia Furlani',
  'commercial-hvac': 'Marcus Sousa',
};
const relatedReviewerName = RELATED_REVIEWER[service.data.urlSlug];
const relatedReview = relatedReviewerName
  ? (await getCollection('testimonials', ({ data }) => data.published && data.reviewerName === relatedReviewerName))[0]
  : undefined;
---

<BaseLayout
  title={service.data.seoTitle}
  description={service.data.metaDescription}
  path={path}
  schema={serviceSchema({ name: service.data.title, description: service.data.shortDescription, path })}
>
  <PageHero
    eyebrow="Services"
    title={service.data.title}
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Services', href: '/services/' },
      { label: service.data.title, href: path },
    ]}
  />

  <section class="service-intro">
    <div class="container intro-grid">
      <div class="intro-image" data-reveal>
        <ResponsiveImage
          src={service.data.image}
          alt={service.data.imageAlt}
          ratio="16 / 11"
          variant="editorial"
          fallbackIcon={service.data.icon}
          sizes="(min-width: 960px) 55vw, 100vw"
        />
      </div>
      <div class="intro-copy" data-reveal>
        <span class="intro-icon"><Icon name={service.data.icon} /></span>
        <p class="intro-lead">{service.data.shortDescription}</p>
        <a href={ctaHref} class="btn btn-primary btn-lg intro-cta">{service.data.ctaLabel}</a>
      </div>
    </div>
  </section>

  <section class="service-body">
    <div class="container service-grid">
      <article class="service-content" data-reveal>
        <Content />
      </article>
      <aside class="service-sidebar" data-reveal>
        <div class="sidebar-card">
          <h3>What's Included</h3>
          <ul class="check-list">
            {service.data.benefits.map((b: string) => (
              <li><Icon name="check" class="icon-sm" /> {b}</li>
            ))}
          </ul>
          <a href={ctaHref} class="btn btn-primary btn-block">{service.data.ctaLabel}</a>
          <a href={`tel:${site.phoneRaw}`} class="btn btn-outline btn-block">
            <Icon name="phone" class="icon-sm" /> {site.phone}
          </a>
        </div>
      </aside>
    </div>
  </section>

  {service.data.gallery && service.data.gallery.length > 0 && (
    <section class="service-gallery-section">
      <div class="container">
        <div class="section-head center">
          <p class="eyebrow">Real Projects</p>
          <h2>{service.data.title} in Action</h2>
        </div>
        <ServiceGallery items={service.data.gallery} />
      </div>
    </section>
  )}

  {relatedReview && (
    <section class="related-review-section">
      <div class="container container-narrow">
        <div class="section-head center">
          <p class="eyebrow">In Their Words</p>
          <h2>What a Recent Customer Said</h2>
        </div>
        <ReviewCard
          reviewerName={relatedReview.data.reviewerName}
          rating={relatedReview.data.rating}
          reviewText={relatedReview.data.reviewText}
          reviewDate={relatedReview.data.reviewDate}
          sourceLabel={relatedReview.data.sourceLabel}
          sourceUrl={relatedReview.data.sourceUrl}
        />
      </div>
    </section>
  )}

  {isEmergency && (
    <section class="emergency-cta-banner">
      <div class="container container-narrow emergency-banner-inner">
        <div>
          <h2>Can't Wait? Call Now.</h2>
          <p>Our emergency line is staffed 24 hours a day, 7 days a week, 365 days a year.</p>
        </div>
        <a href={`tel:${site.phoneRaw}`} class="btn btn-primary btn-lg" data-track="emergency_call_click" data-track-params={JSON.stringify({ location: 'service_page' })}>
          <Icon name="bolt" class="icon-sm" /> Call {site.phone}
        </a>
      </div>
    </section>
  )}

  <section class="section-soft related-section">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">Related Services</p>
        <h2>You May Also Need</h2>
      </div>
      <div class="related-grid">
        {related.map((r) => (
          <ServiceCard title={r.data.title} description={r.data.shortDescription} href={`/${r.data.urlSlug}/`} icon={r.data.icon} />
        ))}
      </div>
    </div>
  </section>

  <CtaSection
    heading={`Ready to Schedule ${service.data.title}?`}
    description="Reach out today for a straightforward estimate, or call our emergency line if you need help right away."
    secondaryCta={{ label: service.data.ctaLabel, href: ctaHref }}
  />
</BaseLayout>

<style>
  .service-intro {
    padding-bottom: 0;
  }
  .intro-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-xl);
    align-items: center;
  }
  .intro-icon {
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    background: var(--color-ice);
    color: var(--color-royal);
    margin-bottom: var(--space-sm);
  }
  .intro-lead {
    font-size: var(--fs-lg);
    color: var(--color-charcoal);
    font-weight: 500;
    max-width: 42ch;
  }
  .intro-cta {
    max-width: 100%;
    white-space: normal;
    text-align: center;
  }
  @media (min-width: 860px) {
    .intro-grid {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    }
  }

  .service-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-2xl);
  }
  .service-content :global(h2) {
    margin-top: var(--space-xl);
  }
  .service-content :global(ul) {
    color: var(--color-muted);
  }
  .service-sidebar {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-md);
    align-content: start;
  }
  .sidebar-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-sm);
    box-shadow: var(--shadow-sm);
  }
  .check-list {
    list-style: none;
    margin: 0 0 var(--space-xs);
    padding: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0.6rem;
    font-size: var(--fs-sm);
  }
  .check-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    color: var(--color-charcoal);
  }
  .check-list :global(svg) {
    color: var(--color-royal);
    flex-shrink: 0;
    margin-top: 0.15rem;
  }
  .icon-sm {
    width: 18px;
    height: 18px;
  }
  .related-grid {
    display: grid;
    gap: var(--space-md);
    grid-template-columns: minmax(0, 1fr);
  }

  @media (min-width: 860px) {
    .service-grid {
      grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
    }
    .service-sidebar {
      position: sticky;
      top: 110px;
    }
  }
  @media (min-width: 720px) {
    .related-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .related-review-section {
    padding-bottom: 0;
  }
  .emergency-cta-banner {
    background: var(--color-ice);
    border-radius: var(--radius-lg);
    max-width: calc(var(--content-max) - 2 * var(--space-md));
    margin-inline: auto;
    padding-block: var(--space-lg);
  }
  .emergency-banner-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    align-items: center;
    text-align: center;
  }
  .emergency-banner-inner h2 {
    margin-bottom: 0.25rem;
  }
  .emergency-banner-inner p {
    margin: 0;
  }
  @media (min-width: 640px) {
    .emergency-banner-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
</style>
