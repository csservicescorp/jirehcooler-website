---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';
import ServiceCard from '@components/ServiceCard.astro';
import CtaSection from '@components/CtaSection.astro';

const services = (await getCollection('services', ({ data }) => data.published)).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="AC Services in South Florida | Jireh Cooler"
  description="Explore all residential and commercial air conditioning services from Jireh Cooler, serving Broward and Palm Beach County since 1994."
  path="/services/"
>
  <PageHero
    eyebrow="Services"
    title="Complete Air Conditioning Services"
    description="From emergency repairs to full installations and everything in between, our certified team handles every part of your comfort system."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Services', href: '/services/' },
    ]}
  />

  <section>
    <div class="container">
      <div class="services-grid">
        {services.map((service) => (
          <ServiceCard title={service.data.title} description={service.data.shortDescription} href={`/${service.data.urlSlug}/`} icon={service.data.icon} />
        ))}
      </div>
    </div>
  </section>

  <CtaSection heading="Not Sure What You Need?" description="Call our team and describe what's going on. We'll point you to the right service and give you a clear next step." />
</BaseLayout>

<style>
  .services-grid {
    display: grid;
    gap: var(--space-md);
    grid-template-columns: minmax(0, 1fr);
  }
  @media (min-width: 720px) {
    .services-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (min-width: 960px) {
    .services-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
