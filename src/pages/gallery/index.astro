---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';
import ResponsiveImage from '@components/ResponsiveImage.astro';
import CtaSection from '@components/CtaSection.astro';

const items = await getCollection('gallery', ({ data }) => data.published);

const iconByCategory: Record<string, string> = {
  installation: 'install',
  commercial: 'building',
  repair: 'wrench',
  maintenance: 'thermostat',
  residential: 'home',
};
---

<BaseLayout
  title="Services in Action | Jireh Cooler"
  description="A look at Jireh Cooler's team, fleet, and the kind of residential and commercial HVAC work we handle across Broward and Palm Beach County."
  path="/gallery/"
>
  <PageHero
    eyebrow="Gallery"
    title="Services in Action"
    description="A look at our team and fleet, and the kind of residential and commercial HVAC work we handle every day. More real project photos are added here as they become available."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Gallery', href: '/gallery/' },
    ]}
  />

  <section>
    <div class="container">
      <div class="gallery-grid">
        {items.map((item, i) => (
          <figure class:list={['gallery-item', { tall: i % 5 === 0 }]} data-reveal style={`transition-delay:${(i % 6) * 50}ms`}>
            <ResponsiveImage
              src={item.data.image}
              alt={item.data.alt}
              ratio={i % 5 === 0 ? '3 / 4' : '4 / 3'}
              variant="gallery"
              fallbackIcon={iconByCategory[item.data.category] ?? 'building'}
              sizes="(min-width: 960px) 33vw, (min-width: 720px) 50vw, 100vw"
            />
            <figcaption>{item.data.title}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <CtaSection heading="Have a Project in Mind?" description="Request an estimate and let's talk about what your space needs." />
</BaseLayout>

<style>
  .gallery-grid {
    display: grid;
    gap: var(--space-md);
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .gallery-item {
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius-lg);
  }
  .gallery-item :global(img:hover) {
    transform: scale(1.05);
  }
  .gallery-item figcaption {
    margin-top: 0.6rem;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--fs-sm);
    color: var(--color-royal);
  }
  @media (min-width: 720px) {
    .gallery-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    .gallery-item.tall {
      grid-row: span 2;
    }
  }
</style>
