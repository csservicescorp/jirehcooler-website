# Copy this file to .env for local Wrangler/Cloudflare Pages Functions testing.
# In production, set these as encrypted environment variables in the Cloudflare
# Pages dashboard (Settings > Environment Variables). Never commit real values.
# See FORM_SETUP.md for full setup instructions.

# Resend (https://resend.com) API key used to send Request an Estimate / Contact
# form submissions by email. Resend has a free tier suitable for this volume.
RESEND_API_KEY=

# The inbox that should receive form submissions (e.g. coolerac1@gmail.com)
ESTIMATE_TO_EMAIL=

# The verified sending address/domain configured in Resend
ESTIMATE_FROM_EMAIL=

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). Optional — analytics
# is only loaded when this is set. Get this from the client's GA4 property
# under Admin > Data Streams. Leave blank until a real ID is provided; a
# placeholder/invented ID must never be used. This is a PUBLIC_-prefixed
# build-time variable (set in the Cloudflare Pages dashboard under
# Settings > Environment Variables, and the site must be rebuilt/redeployed
# after adding it — it is not read at request time).
PUBLIC_GA4_ID=
